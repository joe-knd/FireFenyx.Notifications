<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FireFenyx.WinUI.Notifications.SampleApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:notifications="using:FireFenyx.WinUI.Notifications.Controls"
    Title="FireFenyx.WinUI.Notifications.SampleApp"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="Root">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Bar Style:" VerticalAlignment="Center" />
                <ComboBox MinWidth="140"
                          ItemsSource="{x:Bind ViewModel.BarStyleOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedBarStyle, Mode=TwoWay}" />
            </StackPanel>

            <Button Command="{x:Bind ViewModel.ShowSuccessCommand}" Content="Show Success" />
            <Button Command="{x:Bind ViewModel.ShowWarningCommand}" Content="Show Warning" />
            <Button Command="{x:Bind ViewModel.ShowErrorCommand}" Content="Show Error" />
            <Button Command="{x:Bind ViewModel.ShowProgressCommand}" Content="Show Progress" />
            <Button Command="{x:Bind ViewModel.SendFileComplexScenarioCommand}" Content="Send File (complex)" />
            <Button Command="{x:Bind ViewModel.ShowPersistentNoConnectionCommand}" Content="Show Persistent (no connection)" />
            <Button Command="{x:Bind ViewModel.DismissPersistentCommand}" Content="Dismiss Persistent" />
        </StackPanel>

        <!--  Notification Host  -->
        <notifications:NotificationHost
            x:Name="Notifications"
            BarStyle="{x:Bind ViewModel.SelectedBarStyle, Mode=OneWay}"
            HostPosition="Bottom"
            DefaultDurationMs="4000"
            DefaultTransition="SlideAndFade"
            DefaultMaterial="Acrylic"
            HostHorizontalAlignment="Center"
            HostSpacing="10"
            HostPadding="0,0,0,8" />


    </Grid>
</Window>
