<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="NotificationSolidBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="NotificationForegroundBrush" Color="#202020" />

    <AcrylicBrush
        x:Key="NotificationAcrylicBrush"
        FallbackColor="#F0F0F0"
        TintColor="#F0F0F0"
        TintOpacity="0.7" />

    <SolidColorBrush x:Key="NotificationMicaBrush" Color="#F5F5F5" />

    <!--  Severity accent brushes (used in Accent bar style)  -->
    <SolidColorBrush x:Key="NotificationSuccessBrush" Color="#0F7B0F" />
    <SolidColorBrush x:Key="NotificationInfoBrush" Color="#0063B1" />
    <SolidColorBrush x:Key="NotificationWarningBrush" Color="#9D5D00" />
    <SolidColorBrush x:Key="NotificationErrorBrush" Color="#C42B1C" />

</ResourceDictionary>
