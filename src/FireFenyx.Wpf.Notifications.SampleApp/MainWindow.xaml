<Window x:Class="FireFenyx.Wpf.Notifications.SampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:notifications="clr-namespace:FireFenyx.Wpf.Notifications.Controls;assembly=FireFenyx.Wpf.Notifications"
        xmlns:notifyModels="clr-namespace:FireFenyx.Notifications.Models;assembly=FireFenyx.Notifications.Abstractions"
        Title="FireFenyx.Wpf.Notifications.SampleApp"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Grid x:Name="Root">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="Margin" Value="0,6" />
                    <Setter Property="Padding" Value="16,8" />
                    <Setter Property="MinWidth" Value="220" />
                </Style>
            </StackPanel.Resources>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="Bar Style:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox MinWidth="140"
                          SelectedValue="{Binding SelectedBarStyle}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="AccentStrip" Tag="{x:Static notifyModels:NotificationBarStyle.AccentStrip}" />
                    <ComboBoxItem Content="Fluent" Tag="{x:Static notifyModels:NotificationBarStyle.Fluent}" />
                </ComboBox>
            </StackPanel>

            <Button Command="{Binding ShowSuccessCommand}" Content="Show Success" />
            <Button Command="{Binding ShowWarningCommand}" Content="Show Warning" />
            <Button Command="{Binding ShowErrorCommand}" Content="Show Error" />
            <Button Command="{Binding ShowProgressCommand}" Content="Show Progress" />
            <Button Command="{Binding SendFileComplexScenarioCommand}" Content="Send File (complex)" />
            <Button Command="{Binding ShowPersistentNoConnectionCommand}" Content="Show Persistent (no connection)" />
            <Button Command="{Binding DismissPersistentCommand}" Content="Dismiss Persistent" />
        </StackPanel>

        <!--  Notification Host  -->
        <notifications:NotificationHost
            x:Name="Notifications"
            BarStyle="{Binding SelectedBarStyle}"
            HostPosition="Bottom"
            DefaultDurationMs="4000"
            DefaultTransition="SlideAndFade"
            DefaultMaterial="Acrylic"
            HostHorizontalAlignment="Center"
            HostSpacing="10"
            HostPadding="0,0,0,8" />
    </Grid>
</Window>
