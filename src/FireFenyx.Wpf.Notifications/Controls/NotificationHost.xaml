<UserControl
    x:Class="FireFenyx.Wpf.Notifications.Controls.NotificationHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <!--
        NotificationHost
        
        A WPF UserControl used as a visual host for toast-like in-app notifications.
        Bind/attach an INotificationQueue via NotificationHostService.Queue to enable display.
    -->
    <Grid x:Name="Overlay" IsHitTestVisible="False">
        <StackPanel x:Name="Stack" />
    </Grid>
</UserControl>
