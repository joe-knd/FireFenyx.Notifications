<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="NotificationSolidBrush" Color="#333333" />
    <SolidColorBrush x:Key="NotificationForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="NotificationAcrylicBrush" Color="#E0202020" />
    <SolidColorBrush x:Key="NotificationMicaBrush" Color="#202020" />

    <!--  Severity accent brushes  -->
    <SolidColorBrush x:Key="NotificationSuccessBrush" Color="#0F7B0F" />
    <SolidColorBrush x:Key="NotificationInfoBrush" Color="#0063B1" />
    <SolidColorBrush x:Key="NotificationWarningBrush" Color="#9D5D00" />
    <SolidColorBrush x:Key="NotificationErrorBrush" Color="#C42B1C" />

    <!--  Filled-mode severity background brushes  -->
    <SolidColorBrush x:Key="NotificationSuccessFilledBrush" Color="#FF26452D" />
    <SolidColorBrush x:Key="NotificationInfoFilledBrush" Color="#FF263545" />
    <SolidColorBrush x:Key="NotificationWarningFilledBrush" Color="#FF453B26" />
    <SolidColorBrush x:Key="NotificationErrorFilledBrush" Color="#FF442626" />

</ResourceDictionary>
